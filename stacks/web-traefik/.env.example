# ── App ───────────────────────────────────────────────────────────────────────
APP_IMAGE=your-registry/your-app:latest
APP_PORT=8000

# ── Ports ─────────────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
DASHBOARD_PORT=8080

# ── PostgreSQL (non-secret config) ───────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_DB=app

# ── Domain (for Traefik's automatic Let's Encrypt) ────────────────────────────
DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com

# ── Traefik dashboard ─────────────────────────────────────────────────────────
# Disabled by default. If you enable it, also put a basic-auth middleware in
# front before exposing it beyond 127.0.0.1 — the dashboard has no built-in
# authentication of its own.
TRAEFIK_DASHBOARD_ENABLE=false
TRAEFIK_DASHBOARD_HOST=traefik.example.com
TRAEFIK_LOG_LEVEL=INFO

# ── Passwords are stored in secrets/ directory (NOT here) ─────────────────────
# Run: ./scripts/setup.sh to generate secrets/postgres_password.txt etc.
# See: docs/deploy-targets.md for Docker Secrets setup
