# ── App ───────────────────────────────────────────────────────────────────────
APP_IMAGE=your-registry/your-app:latest
APP_PORT=8000
HTTP_PORT=80
HTTPS_PORT=443

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=app

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-grafana-password
GRAFANA_PORT=3000

# ── CrowdSec ──────────────────────────────────────────────────────────────────
CROWDSEC_BOUNCER_KEY=generate-with-crowdsec-clikey-add-name-bouncer

# ── Domain / SSL ──────────────────────────────────────────────────────────────
DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com
TZ=UTC
