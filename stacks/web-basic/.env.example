# ── App ───────────────────────────────────────────────────────────────────────
APP_IMAGE=your-registry/your-app:latest
APP_PORT=8000

# ── Ports ─────────────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=app

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password

# ── Domain (for nginx + certbot) ──────────────────────────────────────────────
DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com
